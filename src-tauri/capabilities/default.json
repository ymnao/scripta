{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "default",
	"description": "enables the default permissions",
	"windows": ["main", "window-*", "pdf-export-*", "conflict-*"],
	"permissions": [
		"core:default",
		"core:window:allow-close",
		"core:window:allow-destroy",
		"core:window:allow-start-dragging",
		"dialog:default",
		"shell:allow-open",
		"store:allow-get",
		"store:allow-set",
		"store:allow-save",
		"store:allow-load",
		"store:allow-delete"
	]
}
