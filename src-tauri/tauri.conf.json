{
	"$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
	"productName": "mark-draft",
	"version": "0.1.0",
	"identifier": "com.mark-draft.app",
	"build": {
		"frontendDist": "../dist",
		"devUrl": "http://localhost:1420",
		"beforeDevCommand": "pnpm dev",
		"beforeBuildCommand": "pnpm build"
	},
	"app": {
		"windows": [
			{
				"label": "main",
				"title": "mark-draft",
				"width": 800,
				"height": 600,
				"resizable": true,
				"fullscreen": false,
				"titleBarStyle": "Overlay",
				"hiddenTitle": true
			}
		],
		"security": {
			"csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost https:; style-src 'self' 'unsafe-inline'"
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
