{
	"$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
	"assist": { "actions": { "source": { "organizeImports": "on" } } },
	"plugins": [
		"./plugins/no-navigator-platform.grit",
		"./plugins/no-navigator-platform-optional.grit",
		"./plugins/no-navigator-platform-optional-userAgent.grit",
		"./plugins/no-navigator-platform-optional-bracket.grit",
		"./plugins/no-navigator-platform-destruct.grit"
	],
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended",
			"suspicious": {
				"noExplicitAny": "error"
			},
			"nursery": {
				"noFloatingPromises": "error"
			},
			"a11y": {
				"noStaticElementInteractions": "error"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "always"
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"json": {
		"parser": {
			"allowComments": true,
			"allowTrailingCommas": true
		}
	},
	"files": {
		"includes": [
			"**",
			"!**/node_modules",
			"!**/dist",
			"!**/out",
			"!**/release",
			"!**/.claude",
			"!**/test-results",
			"!**/playwright-report",
			"!**/playwright-report-electron"
		]
	},
	"overrides": [
		{
			"includes": ["e2e/electron/helpers/launch.ts"],
			"linter": {
				"rules": {
					"correctness": {
						"noEmptyPattern": "off"
					}
				}
			}
		}
	]
}
