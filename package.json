{
	"name": "scripta-next",
	"private": true,
	"version": "0.0.0",
	"license": "MIT",
	"main": "out/main/index.js",
	"packageManager": "pnpm@11.1.1",
	"engines": {
		"node": ">=22.13.0"
	},
	"scripts": {
		"postinstall": "node node_modules/electron/install.js",
		"dev": "node node_modules/electron/install.js && electron-vite dev",
		"dev:e2e": "vite --config vite.config.e2e.ts",
		"build": "electron-vite build",
		"preview": "node node_modules/electron/install.js && electron-vite preview",
		"dist": "node node_modules/electron/install.js && electron-vite build && electron-builder --publish never",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
		"typecheck:e2e": "tsc --noEmit -p tsconfig.e2e.json",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "node node_modules/electron/install.js && playwright test",
		"test:e2e:ui": "node node_modules/electron/install.js && playwright test --ui"
	},
	"dependencies": {
		"@codemirror/autocomplete": "^6.20.1",
		"@codemirror/commands": "^6.10.2",
		"@codemirror/lang-markdown": "^6.5.0",
		"@codemirror/language": "^6.12.3",
		"@codemirror/language-data": "^6.5.2",
		"@codemirror/search": "^6.6.0",
		"@codemirror/state": "^6.6.0",
		"@codemirror/view": "^6.41.0",
		"@lezer/highlight": "^1.2.3",
		"@uiw/react-codemirror": "^4.25.9",
		"chokidar": "^5.0.0",
		"dompurify": "^3.4.2",
		"js-yaml": "^4.1.1",
		"katex": "^0.16.45",
		"lucide-react": "^1.8.0",
		"marked": "^18.0.3",
		"mermaid": "^11.14.0",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"simple-git": "^3.36.0",
		"write-file-atomic": "^7.0.1",
		"zustand": "^5.0.12"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@electron-toolkit/preload": "^3.0.2",
		"@electron-toolkit/utils": "^4.0.0",
		"@playwright/test": "^1.59.1",
		"@tailwindcss/vite": "^4.2.4",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/js-yaml": "^4.0.9",
		"@types/katex": "^0.16.8",
		"@types/node": "^25.7.0",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@types/write-file-atomic": "^4.0.3",
		"@vitejs/plugin-react": "^6.0.1",
		"electron": "^42.0.0",
		"electron-builder": "^26.8.1",
		"electron-vite": "^5.0.0",
		"jsdom": "^29.1.1",
		"tailwindcss": "^4.2.4",
		"typescript": "~6.0.3",
		"vite": "^8.0.11",
		"vitest": "^4.1.4"
	}
}
